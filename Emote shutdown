-- [[ CONFIGURAÇÃO DA GUI DARK MINIMALISTA ]] --
local ScreenGui = Instance.new("ScreenGui")
local FreezeButton = Instance.new("ImageButton")
local UICorner = Instance.new("UICorner")
local UIBorder = Instance.new("UIStroke") -- Componente de borda

-- IDs fornecidos
local ID_MOVENDO = "rbxassetid://81535859369808"
local ID_PARALISADO = "rbxassetid://122677467476123"

-- Configuração da ScreenGui
ScreenGui.Name = "FreezeEmote_DarkV3"
ScreenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")
ScreenGui.ResetOnSpawn = false

-- Configuração do Botão
FreezeButton.Name = "FreezeButton"
FreezeButton.Parent = ScreenGui
FreezeButton.BackgroundColor3 = Color3.fromRGB(20, 20, 20) -- Grafite Escuro
FreezeButton.BackgroundTransparency = 0.2
FreezeButton.Position = UDim2.new(0.85, 0, 0.70, 0)
FreezeButton.Size = UDim2.new(0, 5, 0, 5) -- Tamanho levemente reduzido para elegância
FreezeButton.Image = ID_MOVENDO
FreezeButton.ScaleType = Enum.ScaleType.Fit
FreezeButton.ZIndex = 2

-- Arredondamento Perfeito (Círculo)
UICorner.CornerRadius = UDim.new(1, 0)
UICorner.Parent = FreezeButton

-- Configuração da Borda (UIStroke)
UIBorder.Parent = FreezeButton
UIBorder.Color = Color3.fromRGB(0, 0, 0) -- Preto absoluto
UIBorder.Thickness = 2 -- Borda fina conforme solicitado
UIBorder.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

-- [[ SISTEMA DE ARRASTAR (DRAGGABLE) ]] --
local dragging, dragInput, dragStart, startPos
local function update(input)
    local delta = input.Position - dragStart
    FreezeButton.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

FreezeButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = FreezeButton.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

FreezeButton.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
    if input == dragInput and dragging then update(input) end
end)

-- [[ LÓGICA DE CONGELAMENTO ]] --
local isPaused = false

FreezeButton.MouseButton1Click:Connect(function()
    local character = game.Players.LocalPlayer.Character
    if not character then return end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    isPaused = not isPaused
    
    if isPaused then
        -- Estado: CONGELADO (ID 2)
        FreezeButton.Image = ID_PARALISADO
        
        local playingTracks = humanoid:GetPlayingAnimationTracks()
        for _, track in ipairs(playingTracks) do
            track:AdjustSpeed(0)
        end
    else
        -- Estado: MOVENDO (ID 1)
        FreezeButton.Image = ID_MOVENDO
        
        local playingTracks = humanoid:GetPlayingAnimationTracks()
        for _, track in ipairs(playingTracks) do
            track:AdjustSpeed(1)
        end
    end
end)

print("Script carregado: Botão Dark com Bordas Pretas ativado!")
